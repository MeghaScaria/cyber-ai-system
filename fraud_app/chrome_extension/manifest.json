{
  "manifest_version": 3,
  "name": "Fraud AI Shield",
  "description": "AI-powered phishing and fraud detection for safer browsing",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Fraud AI Shield",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}