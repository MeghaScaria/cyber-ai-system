{
  "manifest_version": 3,
  "name": "Fraud AI Shield",
  "description": "AI-powered phishing and fraud detection for safer browsing",
  "version": "1.3",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Fraud AI Shield",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "warning.html",
        "warning.js",
        "history.html",
        "history.js",
        "styles.css",
        "alert.mp3"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://127.0.0.1:8000 http://localhost:8000"
  }
}